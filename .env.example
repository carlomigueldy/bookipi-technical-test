# Flash sale system — environment variable contract.
# Canonical spellings are FROZEN by .claude/contracts/phase-0.md §11.
# Copy to `.env` for local (non-compose) `pnpm dev` runs. Never commit `.env`.
# In-network (docker compose) values differ for DATABASE_URL/REDIS_URL/CORS_ORIGIN/
# VITE_API_BASE_URL — those are set explicitly in infra/docker-compose.yml, not read from here.

# runtime
NODE_ENV=development
LOG_LEVEL=info

# ports
API_HOST=0.0.0.0
API_PORT=3000
WORKER_HEALTH_PORT=3001
WEB_PORT=5173

# datastores
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api
DATABASE_URL=postgresql://flash:flash@localhost:5433/flash
REDIS_URL=redis://localhost:6380

# sale
SALE_ID=flash-2026
SALE_NAME=Aurora — Founders Edition
SALE_STARTS_AT=2026-07-22T12:00:00.000Z
SALE_ENDS_AT=2026-07-22T13:00:00.000Z
SALE_TOTAL_STOCK=500

# rate limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=1000

# queue
ORDERS_QUEUE_NAME=orders
WORKER_CONCURRENCY=16
WORKER_MAX_ATTEMPTS=5

# compose only (used by the postgres service in infra/docker-compose.yml)
POSTGRES_USER=flash
POSTGRES_PASSWORD=flash
POSTGRES_DB=flash

# test
# optional; when unset the redis package's unit tests start a throwaway container via testcontainers.
REDIS_TEST_URL=
