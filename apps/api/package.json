{
  "name": "@flash/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build -p tsconfig.build.json && node ../../scripts/assert-build-output.mjs dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@flash/redis": "workspace:*",
    "@flash/shared": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "bullmq": "^5.63.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.4.0",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@flash/tooling": "workspace:*",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/redis": "^12.0.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.5",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.1.2",
    "testcontainers": "^12.0.4",
    "typescript": "^5.7.2",
    "undici": "^7.16.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^3.2.6"
  }
}
